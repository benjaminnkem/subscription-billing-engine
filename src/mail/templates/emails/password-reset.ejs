<%- include('../partials/header', { title: 'Reset your password', appName }) %>
<p class="text-body">Hi <span class="text-strong"><%= userName %></span>,</p>
<p class="text-body">
  We received a request to reset your password. Click the button below to choose a new one.
</p>
<p class="text-body" style="text-align:center;padding:8px 0 20px;">
  <a href="<%= resetUrl %>" class="btn-primary">Reset password</a>
</p>
<p class="text-body text-muted" style="font-size:13px;">
  This link expires in 1 hour. If you did not request a reset, you can ignore this email.
</p>
<%- include('../partials/footer', { appName }) %>